# Yield Curve Monitor - Environment Variables

# FRED API (required)
# Get a free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Database (PostgreSQL)
# Local development
DATABASE_URL=postgresql://localhost:5432/yield_curve
# VPS/Production (uncomment when deploying)
# DATABASE_URL=postgresql://user:password@localhost:5432/yield_curve

# Backend URL (for Next.js API proxying)
BACKEND_URL=http://localhost:8053

# Public site URL (OpenGraph / social previews)
NEXT_PUBLIC_SITE_URL=http://localhost:3053

# Server ports
# Frontend: 3053
# Backend: 8053
