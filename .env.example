# Yield Curve Monitor - Environment Variables

# FRED API (required)
FRED_API_KEY=your_fred_api_key_here

# Storage backend: sqlite (local dev) | postgres (VPS — same DB as Market Color)
CURVE_STORE_BACKEND=sqlite

# PostgreSQL (VPS — reuse Market Color secrets: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=financial_data_db
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# SQLite fallback path (local dev)
SQLITE_CACHE_PATH=backend/app/data/yield_curve_cache.sqlite
CURVE_CACHE_MAX_AGE_HOURS=18
MACRO_SYNC_MAX_AGE_HOURS=24

# Backend URL (Next.js API proxy)
BACKEND_URL=http://localhost:8053

# Public URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3053

# Server ports (local dev): frontend 3053, backend 8053
# Production VPS: frontend 3059, backend 8059
